db.feedback.aggregate([
  {
    $match: {
      semester: "2022-ODD"
    }
  },
  {
    $group: {
      _id: "$course_code",
      avg_rating: { $avg: "$rating" },
      total_feedback: { $sum: 1 }
    }
  },
  {
    $sort: {
      avg_rating: -1
    }
  }
])

[
  { _id: 'CS102', avg_rating: 5, total_feedback: 1 },
  { _id: 'CE101', avg_rating: 5, total_feedback: 1 },
  { _id: 'CS101', avg_rating: 4.5, total_feedback: 2 },
  { _id: 'CS103', avg_rating: 4, total_feedback: 1 },
  { _id: 'EC101', avg_rating: 2, total_feedback: 1 }
]

db.feedback.aggregate([
  {
    $match: {
      semester: "2022-ODD"
    }
  },
  {
    $group: {
      _id: "$course_code",
      avg_rating: { $avg: "$rating" },
      total_feedback: { $sum: 1 }
    }
  },
  {
    $project: {
      _id: 0,
      course_code: "$_id",
      average_rating: {
        $round: ["$avg_rating", 1]
      },
      total_feedback: 1
    }
  },
  {
    $sort: {
      average_rating: -1
    }
  }
])

[
  { total_feedback: 1, course_code: 'CS102', average_rating: 5 },
  { total_feedback: 1, course_code: 'CE101', average_rating: 5 },
  { total_feedback: 2, course_code: 'CS101', average_rating: 4.5 },
  { total_feedback: 1, course_code: 'CS103', average_rating: 4 },
  { total_feedback: 1, course_code: 'EC101', average_rating: 2 }
]

 db.feedback.aggregate([
|   {
|     $unwind: "$tags"
|   },
|   {
|     $group: {
|       _id: "$tags",
|       count: { $sum: 1 }
|     }
|   },
|   {
|     $sort: {
|       count: -1
|     }
|   }
| ])
[
  { _id: 'clear', count: 2 },
  { _id: 'practical', count: 2 },
  { _id: 'difficult', count: 1 },
  { _id: 'structured', count: 1 },
  { _id: 'interactive', count: 1 },
  { _id: 'moderate', count: 1 },
  { _id: 'hands-on', count: 1 },
  { _id: 'interesting', count: 1 },
  { _id: 'reviewed', count: 1 },
  { _id: 'average', count: 1 },
  { _id: 'engaging', count: 1 },
  { _id: 'excellent', count: 1 }
]

db.feedback.createIndex({
  course_code:1
})

